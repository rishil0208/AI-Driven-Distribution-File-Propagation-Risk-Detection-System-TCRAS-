        <mxCell id="m6y" parent="1" value="" style="line;html=1;strokeWidth=2;strokeColor#9B59B6;dashed=1;" edge="1" source="l5" target="l3">
          <mxGeometry x="0.5" y="835" width="100" height="20" as="geometry">
            <mxPoint x="820" y="835" as="sourcePoint" />
            <mxPoint x="460" y="835" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- ARROW 7: Server saves to Database -->
        <mxCell id="m7" edge="1" parent="1" source="l3" target="l6" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;endArrow=classic;strokeColor=#FF6B6B;labelBackgroundColor=#ffffff;" value="7: INSERT EventLog Record">
          <mxGeometry relative="1" y="-20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m7y" parent="1" value="" style="line;html=1;strokeWidth=2;strokeColor#FF6B6B;" edge="1" source="l3" target="l6">
          <mxGeometry x="0.5" y="900" width="100" height="20" as="geometry">
            <mxPoint x="460" y="900" as="sourcePoint" />
            <mxPoint x="1000" y="900" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- STEP 6: Database insertion -->
        <mxCell id="s6" parent="1" style="rounded=1;fillColor#E8F8F0;strokeWidth=2;fontSize=10;fontColor=#000000;align=center;verticalAlign=middle;" value="7.a: Create EventLog&#10;7.b: Store:&#10;- Filename, Hash&#10;- IPs, Timestamp&#10;- Risk Score/Level&#10;7.c: Commit Transaction" vertex="1">
          <mxGeometry height="90" width="130" x="935" y="955" as="geometry" />
        </mxCell>
        
        <!-- ARROW 8: Database confirms -->
        <mxCell id="m8" edge="1" parent="1" source="l6" target="l3" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;endArrow=classic;strokeColor:#3498DB;dashed=1;labelBackgroundColor=#ffffff;" value="8: Confirmation (ID)">
          <mxGeometry relative="1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m8y" parent="1" value="" style="line;html=1;strokeWidth=2;strokeColor#3498DB;dashed=1;" edge="1" source="l6" target="l3">
          <mxGeometry x="0.5" y="1085" width="100" height="20" as="geometry">
            <mxPoint x="1000" y="1085" as="sourcePoint" />
            <mxPoint x="460" y="1085" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- ARROW 9: Server to Dashboard (SSE Broadcast) -->
        <mxCell id="m9" edge="1" parent="1" source="l3" target="l7" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;endArrow=classic;strokeColor:#FF6B6B;labelBackgroundColor=#ffffff;" value="9: Broadcast via SSE">
          <mxGeometry relative="1" y="-20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m9y" parent="1" value="" style="line;html=1;strokeWidth=2;strokeColor#FF6B6B;" edge="1" source="l3" target="l7">
          <mxGeometry x="0.5" y="1150" width="100" height="20" as="geometry">
            <mxPoint x="460" y="1150" as="sourcePoint" />
            <mxPoint x="1180" y="1150" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- STEP 7: Dashboard receives and updates -->
        <mxCell id="s7" parent="1" style="rounded=1;fillColor#F0E8F8;strokeWidth=2;fontSize=10;fontColor=#000000;align=center;verticalAlign=middle;" value="9.a: Receive Event&#10;9.b: Update Graph Nodes&#10;9.c: Animate Node Addition&#10;9.d: Update Risk Log&#10;9.e: Refresh Dashboard" vertex="1">
          <mxGeometry height="90" width="130" x="1115" y="1205" as="geometry" />
        </mxCell>
        
        <!-- ARROW 10: Dashboard sends response to Agent -->
        <mxCell id="m10" edge="1" parent="1" source="l3" target="l2" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeWidth=2;endArrow=classic;strokeColor:#50C878;dashed=1;labelBackgroundColor=#ffffff;" value="10: HTTP 200 OK (RiskAnalysis JSON)">
          <mxGeometry relative="1" y="20" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m10y" parent="1" value="" style="line;html=1;strokeWidth=2;strokeColor#50C878;dashed=1;" edge="1" source="l3" target="l2">
          <mxGeometry x="0.5" y="1350" width="100" height="20" as="geometry">
            <mxPoint x="460" y="1350" as="sourcePoint" />
            <mxPoint x="280" y="1350" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- STEP 8: Agent completes -->
        <mxCell id="s8" parent="1" style="rounded=1;fillColor#F0F8E8;strokeWidth=2;fontSize=10;fontColor#000000;align=center;verticalAlign=middle;" value="10.a: Log Response&#10;10.b: Process Complete&#10;10.c: Ready for Next Event" vertex="1">
          <mxGeometry height="70" width="130" x="215" y="1400" as="geometry" />
        </mxCell>
        
        <!-- LEGEND BOX -->
        <mxCell id="legend" parent="1" style="rounded=1;fillColor:#F5F5F5;strokeWidth=2;strokeColor:#999999;fontSize=10;fontColor:#000000;align=left;verticalAlign=top;" value="LEGEND:&#10;━━ Solid Arrow = Synchronous Request&#10;- - - Dashed Arrow = Return/Response&#10;⚙ = Processing Step&#10;💾 = Database Operation" vertex="1">
          <mxGeometry height="80" width="250" x="30" y="1520" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
