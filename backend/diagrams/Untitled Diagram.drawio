        <mxCell id="info" parent="1" style="rounded=1;fillColor=none;strokeWidth=2;fontSize=9;align=center;verticalAlign=middle;strokeColor=#000000;" value="KEY FEATURES:&#xa;• Real-time file monitoring via Watchdog&#xa;• FastAPI server for scalability&#xa;• NetworkX for transfer chain analysis&#xa;• ML-based risk scoring (Isolation Forest)&#xa;• SQLite for persistent storage&#xa;• Server-Sent Events (SSE) for live updates&#xa;• Interactive Vis.js graph visualization" vertex="1">
          <mxGeometry height="130" width="320" x="50" y="520" as="geometry" />
        </mxCell>
        <mxCell id="dataflow" parent="1" style="rounded=1;fillColor=none;strokeWidth=2;fontSize=9;align=center;verticalAlign=middle;fontStyle=1;strokeColor=#000000;" value="DATA FLOW PIPELINE:&#xa;1. File created → Agent detects (Watchdog)&#xa;2. Agent → Server API (HTTP POST)&#xa;3. Server → Graph Engine (add transfer)&#xa;4. Graph Engine → Server (return features)&#xa;5. Server → Risk Engine (calculate score)&#xa;6. Risk Engine → Server (return risk level)&#xa;7. Server → Database (persist event)&#xa;8. Server → Dashboard (SSE broadcast)&#xa;9. Dashboard → User (visual update)" vertex="1">
          <mxGeometry height="145" width="350" x="420" y="520" as="geometry" />
        </mxCell>
        <mxCell id="tech" parent="1" style="rounded=1;fillColor=none;strokeWidth=2;fontSize=9;align=center;verticalAlign=middle;strokeColor=#000000;" value="TECHNOLOGIES:&#xa;Backend: Python, FastAPI, Uvicorn&#xa;Monitoring: Watchdog&#xa;Graph: NetworkX&#xa;ML: Scikit-learn (Isolation Forest)&#xa;Database: SQLite, SQLAlchemy&#xa;Frontend: HTML5, TailwindCSS&#xa;Visualization: Vis.js, Anime.js&#xa;UI: Tkinter (ttkbootstrap)" vertex="1">
